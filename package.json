{
  "name": "posemesh-hns-discovery",
  "version": "0.1.1-prototype",
  "description": "Proof-of-concept Handshake .posemesh discovery and identity resolver for Posemesh discussion.",
  "type": "module",
  "license": "MIT",
  "author": "MycophileHNS",
  "repository": {
    "type": "git",
    "url": "https://github.com/MycophileHNS/posemesh-hns-discovery"
  },
  "bugs": {
    "url": "https://github.com/MycophileHNS/posemesh-hns-discovery/issues"
  },
  "homepage": "https://github.com/MycophileHNS/posemesh-hns-discovery#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "posemesh-hns-discovery": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/normalize-declarations.mjs",
    "prepack": "npm run build",
    "resolve": "node --experimental-transform-types src/cli.ts resolve",
    "demo": "node --experimental-transform-types src/cli.ts demo",
    "test": "node --test --experimental-transform-types test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "audit:security": "npm audit --audit-level=moderate",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "posemesh",
    "handshake",
    "hns",
    "discovery",
    "identity"
  ],
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
